{
    "include": [
        "./**/*.js"
    ],
    "compilerOptions": {
        "skipDefaultLibCheck": true,
        "moduleResolution": "classic",
        "composite": true,
        "isolatedModules": true,
        "lib": [
            "ES5",
            "ES2015"
        ],
        "types": [
            "../../.probe/client/packages",
            "../../.probe/client/global",
            "../../.probe/shared"
        ],
        "incremental": true,
        "target": "ES2015",
        "skipLibCheck": true,
        "rootDir": ".",
        "allowJs": true,
        "module": "commonjs"
    }
}